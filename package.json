{
  "name": "ap-services-marketplace",
  "version": "1.0.0",
  "description": "Complete service marketplace platform connecting customers with local professionals - Plumbing, Electrical, Beauty, Tutoring, Security, and 25+ services",
  "main": "backend/server.js",
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "private": false,
  "keywords": [
    "marketplace",
    "service-booking",
    "urban-company-clone",
    "home-services",
    "nodejs",
    "express",
    "postgresql",
    "startup"
  ],
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "prod": "NODE_ENV=production node backend/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint backend/",
    "lint:fix": "eslint backend/ --fix",
    "format": "prettier --write \"backend/**/*.js\"",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset-db.js",
    "postinstall": "npm run db:migrate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "aws-sdk": "^2.1503.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.5",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0-rc2",
    "razorpay": "^2.9.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.19.3",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.10",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/server.js"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "backend"
    ],
    "ext": "js,json",
    "ignore": [
      "backend/tests/*"
    ],
    "exec": "node backend/server.js",
    "env": {
      "NODE_ENV": "development"
    }
  }
}
